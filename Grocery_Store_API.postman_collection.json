          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code must be 200\", () => {\r",
                  "\tpm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "pm.test('At least one available product', () => {\r",
                  "    const response = pm.response.json();\r",
                  "    //We expect response to be an array\r",
                  "    pm.expect(response).to.be.an('array');\r",
                  "    //We expect response length to be greater than 0\r",
                  "    pm.expect(response.length).to.be.above(0);\r",
                  "    \r",
                  "    const firstProduct = response[0];\r",
                  "\r",
                  "    pm.expect(firstProduct).to.be.an('object');\r",
                  "    pm.expect(firstProduct).to.haveOwnProperty('id');\r",
                  "    pm.expect(firstProduct.id).to.be.a('number');\r",
                  "    pm.expect(firstProduct).to.haveOwnProperty('inStock');\r",
                  "    pm.expect(firstProduct.inStock).to.be.true;\r",
                  "\r",
                  "    pm.collectionVariables.set('productId', firstProduct.id);\r",
                  "    \r",
                  "});\r",
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
